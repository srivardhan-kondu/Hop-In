rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /aadhaarDocs/{driverId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == driverId || request.auth.token.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    match /vanPhotos/{driverId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }
  }
}
